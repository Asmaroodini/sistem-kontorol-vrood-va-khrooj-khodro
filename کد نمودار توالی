@startuml

actor "دوربین پلاک‌خوان" as Camera
participant "سیستم کنترل" as System
database "پایگاه داده" as DB
participant "راه‌بند" as Gate

Camera -> System : ارسال شماره پلاک

System -> DB : جستجوی خودرو
DB --> System : اطلاعات خودرو

System -> DB : بررسی سطح دسترسی
DB --> System : نتیجه دسترسی

alt مجوز ورود دارد
    System -> Gate : فرمان باز شدن راه‌بند
    Gate --> System : راه‌بند باز شد
    System -> DB : ثبت ورود/خروج
    DB --> System : ثبت با موفقیت
else مجوز ندارد
    System -> Gate : عدم باز شدن راه‌بند
    Gate --> System : راه‌بند بسته ماند
    System -> DB : ثبت درخواست ناموفق
    DB --> System : ثبت شد
end

@enduml
